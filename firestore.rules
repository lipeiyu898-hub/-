rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bills
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The user ID who owns the bill
    //   - amount: number (required) - The amount of the transaction
    //   - type: string (required, enum: ["expense", "income"]) - Whether it is an expense or income
    //   - category: string (required) - The category ID of the transaction
    //   - note: string (optional) - A brief description or note
    //   - merchant: string (optional) - The name of the merchant
    //   - time: string (optional) - The time of the transaction
    //   - date: timestamp (required) - The date of the transaction
    //   - createdAt: timestamp (required, immutable) - When the record was created
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidBill(data) {
      return data.keys().hasAll(['uid', 'amount', 'type', 'category', 'date', 'createdAt']) &&
             data.uid is string &&
             data.amount is number &&
             data.type in ['expense', 'income'] &&
             data.category is string &&
             data.date is timestamp &&
             data.createdAt is timestamp;
    }

    match /bills/{billId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidBill(request.resource.data);
      allow update: if isDocOwner() &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      isValidBill(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
