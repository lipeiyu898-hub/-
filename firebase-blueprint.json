{
  "entities": {
    "Bill": {
      "title": "Bill",
      "description": "A financial transaction record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who owns the bill" },
        "amount": { "type": "number", "description": "The amount of the transaction" },
        "type": { "type": "string", "enum": ["expense", "income"], "description": "Whether it is an expense or income" },
        "category": { "type": "string", "description": "The category ID of the transaction" },
        "note": { "type": "string", "description": "A brief description or note" },
        "merchant": { "type": "string", "description": "The name of the merchant" },
        "time": { "type": "string", "description": "The time of the transaction" },
        "date": { "type": "string", "format": "date-time", "description": "The date of the transaction" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created" }
      },
      "required": ["uid", "amount", "type", "category", "date"]
    }
  },
  "firestore": {
    "/bills/{billId}": {
      "schema": "Bill",
      "description": "Collection of financial bills"
    }
  }
}
